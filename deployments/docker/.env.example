# Copy to .env and fill in real values. docker compose will fail-fast if any are missing.

# Postgres
POSTGRES_USER=multiplayer
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=multiplayer

# Grafana admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-prod

# API
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-with-cryptographically-random-value
